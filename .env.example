# ============================================================
# SpaceRent — Environment Variables (copy to .env and fill in)
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://user:password@host:5432/spaceren

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Optional: pre-created Stripe Price IDs (create in Stripe Dashboard)
# Monthly: £1.00 GBP recurring
# Yearly:  £12.00 GBP recurring
STRIPE_PRICE_ID_MONTH=
STRIPE_PRICE_ID_YEAR=

# --- JWT ---
JWT_SECRET_KEY=change-this-to-a-long-random-string

# --- Frontend ---
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Storage (S3-compatible, e.g. AWS S3, Supabase Storage, MinIO) ---
STORAGE_REGION=us-east-1
STORAGE_BUCKET=spaceren-uploads
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=  # Optional: for S3-compatible non-AWS providers

# --- Admin ---
ADMIN_EMAIL=admin@example.com
